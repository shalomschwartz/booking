# ─── Google OAuth ───────────────────────────────────────────────
# From your Google Cloud Console (APIs & Services → Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Run /api/auth on the deployed URL to get this token
GOOGLE_REFRESH_TOKEN=

# ─── Calendar ───────────────────────────────────────────────────
# Leave as "primary" to use the account's main calendar
CALENDAR_ID=primary

# ─── Schedule ───────────────────────────────────────────────────
# IANA timezone name — e.g. America/New_York, Europe/London, Asia/Jerusalem
TIMEZONE=Asia/Jerusalem

# Working days (0=Sun, 1=Mon, 2=Tue, 3=Wed, 4=Thu, 5=Fri, 6=Sat)
# Sun–Thu:
WORK_DAYS=0,1,2,3,4
# Mon–Fri: WORK_DAYS=1,2,3,4,5

# 24-hour clock — e.g. 9 = 9:00am, 18 = 6:00pm
WORK_START_HOUR=9
WORK_END_HOUR=18

# Slot length in minutes (30 or 60 are typical)
SLOT_DURATION_MINS=30

# ─── Branding ───────────────────────────────────────────────────
BUSINESS_NAME=Your Business Name
# Hex accent color for emails (e.g. #111827, #1D4ED8, #7C3AED)
ACCENT_COLOR=#111827

# ─── Frontend (must be prefixed with VITE_) ─────────────────────
VITE_BUSINESS_NAME=Your Business Name
VITE_SLOT_DURATION_MINS=30
# Same hex accent color as above — controls the UI
VITE_ACCENT_COLOR=#111827
